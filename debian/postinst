#!/bin/bash
set -e

# Install systemd service
if [ "$1" = "configure" ]; then
    # Copy service file to systemd directory
    cp /usr/local/share/portkey-gateway/portkey-gateway.service /etc/systemd/system/

    # Reload systemd daemon to pick up new service file
    systemctl daemon-reload

    echo "Portkey Gateway has been installed."
    echo "To start the service: sudo systemctl start portkey-gateway"
    echo "To view logs: sudo journalctl -u portkey-gateway -f"
fi
