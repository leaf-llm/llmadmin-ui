{
  "applicationId": "com.local-llm-gateway.app",
  "version": "1.0.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/resources/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": true,
    "writeToLogFile": true
  },
  "nativeAllowList": [
    "app.*",
    "os.*",
    "window.navigate",
    "window.setTitle",
    "computer.getKernelInfo",
    "events.*",
    "debug.log",
    "clipboard.*"
  ],
  "modes": {
    "window": {
      "title": "Local LLM Gateway",
      "width": 1280,
      "height": 840,
      "minWidth": 900,
      "minHeight": 600,
      "center": true,
      "exitProcessOnClose": true
    }
  },
  "cli": {
    "binaryName": "local-llm-gateway",
    "resourcesPath": "./resources/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/resources/js/neutralino.js",
    "binaryVersion": "5.5.0",
    "clientVersion": "5.5.0"
  }
}
