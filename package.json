{
  "name": "llm-admin-ui",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "description": "LLM Admin UI desktop and web admin shell (consumes llm-admin-gateway submodule)",
  "scripts": {
    "dev:ui": "vite --port 5173 --strictPort --open",
    "build:ui": "vite build",
    "build:ui:desktop": "vite build --mode desktop",
    "preview": "vite preview --port 5173 --strictPort",
    "build:gateway": "npm --prefix src-gateway run build",
    "build:gateway:plugins": "npm --prefix src-gateway run build-plugins",
    "build:all": "npm run build:gateway && npm run build:gateway:plugins && npm run build:ui",
    "desktop:setup": "cd desktop && neu update",
    "bun:build": "npm --prefix src-gateway run bun:build",
    "bun:dev": "npm --prefix src-gateway run bun:dev",
    "build:desktop": "npm run bun:build && rm -rf desktop/resources/assets desktop/resources/index.html && npm run build:ui:desktop && cd desktop && neu build && node scripts/copy-binary.js",
    "dev:desktop": "cd desktop && node scripts/copy-binary.js && neu run"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/node": "^20.19.0",
    "@vitejs/plugin-react": "latest",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "latest",
    "react-dom": "latest",
    "react-i18next": "^17.0.6",
    "react-router-dom": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest"
  }
}
